{
  "name": "Location Guard",
  "grant": [
    "unsafeWindow",
    "GM_getValue",
    "GM_setValue",
    "GM.getValue",
    "GM.setValue",
    "GM_deleteValue",
    "GM.deleteValue",
    "GM.registerMenuCommand",
    "GM_addValueChangeListener",
    "GM_removeValueChangeListener",
    "GM.addValueChangeListener",
    "GM.removeValueChangeListener"
  ],
  "run-at": "document-end",
  "match": ["*://*/*"],
  "include": ["*://*/*"]
}
