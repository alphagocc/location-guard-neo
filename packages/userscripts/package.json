{
  "name": "location-guard-neo",
  "version": "0.2.2",
  "private": false,
  "description": "A UserScript that hide/spoof your geographic location from websites.",
  "main": "dist/location-guard-neo.user.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "WATCH=true rollup --configPlugin rollup-plugin-swc3 -c --bundleConfigAsCjs --watch",
    "build": "rollup --configPlugin rollup-plugin-swc3 -c --bundleConfigAsCjs"
  },
  "keywords": [
    "userscript",
    "userjs",
    "tampermonkey",
    "violentmonkey",
    "location",
    "location-guard"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "foxact": "^0.3.5",
    "klona": "^2.0.6"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@swc/core": "^1.15.41",
    "@types/greasemonkey": "^4.0.7",
    "@types/greasemonkey3": "npm:@types/greasemonkey@^4.0.7",
    "@types/node": "^25.9.3",
    "location-guard-types": "workspace:*",
    "rollup": "^4.61.1",
    "rollup-plugin-swc3": "^0.12.1",
    "rollup-plugin-userscript-metablock": "^0.4.3",
    "typed-query-selector": "^2.12.2"
  }
}
